# Copy this file to .env for local development.
# Never commit the real .env file -- it's already in .gitignore.

# Required. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-value

# development or production
FLASK_ENV=development

# Optional. Powers live currency conversion via exchangerate-api.com.
# Get a free key at https://www.exchangerate-api.com/
# The app works fine without it -- conversion is just skipped (1:1 rate).
EXCHANGE_RATE_API_KEY=

# Optional. Defaults to instance/fintrack.db
DATABASE_PATH=
